#
# Build helper for the static client library
# (see builds/posix/Makefile.in, target client_static, recipe
# $(LIBFIREBIRD_STATIC)).
#
# The makefile has already created <archive> with STATICLIB_LINK.
# This script then:
#   1. Parses the exported symbol names from the make-processed vers
#      file (firebird.vers).
#   2. "Slims" the archive: ld -r with -u for each exported symbol
#      pulls in only the archive members transitively reachable from
#      those seeds; the cross-reference output identifies which
#      members were pulled in, and only those are repacked.
#   3. Generates a comprehensive symbol rename map from every global
#      defined in the slimmed archive that is NOT in the exported
#      API list. Each such symbol gets a "__fbclient_" prefix.
#   4. Applies the rename map with objcopy --redefine-syms.
#
# Step 2 uses a slim-mode-specific ld flag for the cross-reference:
#   - elf:    GNU ld --cref (writes to stdout, redirected to $CREF)
#   - darwin: Apple ld64 -Wl,-map (writes to $CREF directly)
#
# The seed input is the *make-processed* vers file
# ($(GEN_ROOT)/firebird.vers, regenerated by the %.vers pattern
# rule in Makefile.in via builds/posix/vers.sh.in). Its format
# depends on the build platform:
#   - Linux/FreeBSD/NetBSD (ELF): GNU version script:
#         { global: \tgds__alloc; ... local: \t*; };
#   - Darwin (Mach-O): one Mach-O symbol name per line:
#         \t_gds__alloc
#         \t_gds__attach_database
#         ...
# The parser below keeps lines that contain exactly one
# identifier-shaped token (optionally ending with ';') and
# strips a trailing semicolon, so it handles both formats.

NM=@NM@
LD=@CXX@
AR=@AR@

ARCHIVE=
SEEDS_FILE=
STAGE=
CREF=
PROBE=
OBJCOPY_BIN=
SLIM_MODE=elf

usage() {
	cat >&2 <<EOF
Usage: static_client.sh
   --archive            path to the static client archive (input/output)
   --seeds-file         make-processed vers file with exported symbols
                        (bare names on ELF, leading-underscore on Darwin)
   --stage              scratch dir for extracted archive members
   --cref               cross-reference table from the partial link
   --probe              object produced by the partial link
   --objcopy            objcopy-compatible binary used for --redefine-syms
                        (GNU binutils' objcopy on ELF; llvm-objcopy on Darwin)
   --slim-mode          elf | darwin  (default: elf)
EOF
	exit 1
}

while test $# -gt 0
do
	case "$1" in
	--archive)            ARCHIVE="$2";            shift 2;;
	--seeds-file)         SEEDS_FILE="$2";         shift 2;;
	--stage)              STAGE="$2";              shift 2;;
	--cref)               CREF="$2";               shift 2;;
	--probe)              PROBE="$2";              shift 2;;
	--objcopy)            OBJCOPY_BIN="$2";        shift 2;;
	--slim-mode)          SLIM_MODE="$2";          shift 2;;
	-h|--help)            usage;;
	*)                    echo "static_client.sh: unknown option: $1" >&2; usage;;
	esac
done

if test -z "$ARCHIVE" -o -z "$SEEDS_FILE" -o -z "$PROBE" -o -z "$OBJCOPY_BIN" \
   -o -z "$STAGE" -o -z "$CREF"; then
	usage
fi

case "$SLIM_MODE" in
elf|darwin) ;;
*) echo "static_client.sh: invalid --slim-mode '$SLIM_MODE' (expected elf or darwin)" >&2; exit 1;;
esac

set -eu

# Step 1: Parse exported symbols from the make-processed vers file.
# The awk pattern matches a single identifier-shaped token optionally
# ending with ';', handles both ELF (gds__alloc;) and Darwin (_gds__alloc)
# formats.
SEEDS=$(awk 'NF==1 && $1 ~ /^[_A-Za-z][_A-Za-z0-9]*;?$/ { sub(/;$/,"",$1); print $1 }' \
	"$SEEDS_FILE" | sort -u)

# Step 2: Slim the archive. Partial link seeded with -u per exported
# symbol identifies which archive members are transitively reachable.
rm -rf "$STAGE" "$CREF" "$PROBE"

SEED_FLAGS=$(printf -- '-u %s\n' $SEEDS)

# slim-mode-specific ld flag for cross-reference output
# shellcheck disable=SC2086
if test "$SLIM_MODE" = darwin; then
	$LD -r $SEED_FLAGS "$ARCHIVE" \
		-o "$PROBE" -Wl,-map,"$CREF"
else
	$LD -r $SEED_FLAGS "$ARCHIVE" \
		-o "$PROBE" -Wl,--cref > "$CREF" 2>/dev/null
fi

mkdir -p "$STAGE"
(cd "$STAGE" && $AR x "$ARCHIVE")

MEMBERS=$(sed -nE 's|.*libfbclient\.a\(([^)]+\.o)\).*|\1|p' \
	"$CREF" | sort -u)
if test -z "$MEMBERS"; then
	echo "static client slim: no members pulled - aborting" >&2
	exit 1
fi

rm -f "$ARCHIVE"
(cd "$STAGE" && $AR crus "$ARCHIVE" $MEMBERS)

rm -rf "$STAGE" "$CREF" "$PROBE"

# Step 3: Generate a comprehensive rename map for every defined
# global symbol in the slimmed archive that is NOT in the exported
# API. Each such symbol gets a "__fbclient_" prefix so it won't
# collide with the host application's own symbols (e.g. global
# operator new/delete, decNumber symbols, internal C++ symbols).
#
# On ELF, nm emits bare C names (gds__alloc); on Mach-O it emits
# leading-underscore names (_gds__alloc). Both conventions are
# preserved correctly in the rename pairs because the seed list
# parsed above matches the nm output convention on each platform.
API_SYMS=$(mktemp)
REDEFINE=$(mktemp)
printf '%s\n' $SEEDS > "$API_SYMS"
$NM --defined-only -g "$ARCHIVE" \
	| awk 'NF==3 {print $3}' | sort -u \
	| grep -F -v -x -f "$API_SYMS" \
	| awk '{print $1, "__fbclient_" $1}' \
	> "$REDEFINE"

if test -s "$REDEFINE"; then
	$OBJCOPY_BIN --redefine-syms="$REDEFINE" "$ARCHIVE"
fi

rm -f "$REDEFINE" "$API_SYMS"
